generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL") // Uncomment when you have a working DIRECT_URL for migrations
  // Note: For now, migrations use DATABASE_URL via pooler which works for status/resolve commands
}

model Restaurant {
  id                                   String            @id @default(cuid())
  slug                                 String            @unique
  nameKu                               String
  nameEn                               String
  nameAr                               String
  logoMediaId                          String?
  footerLogoMediaId                    String?
  welcomeBackgroundMediaId             String?
  logoR2Key                            String?
  logoR2Url                            String?
  footerLogoR2Key                      String?
  footerLogoR2Url                      String?
  welcomeBgR2Key                       String?
  welcomeBgR2Url                       String?
  welcomeBgMimeType                    String?
  welcomeOverlayColor                  String            @default("#000000")
  welcomeOverlayOpacity                Float             @default(0.5)
  welcomeTextEn                        String?
  googleMapsUrl                        String?
  phoneNumber                          String?
  instagramUrl                         String?
  snapchatUrl                          String?
  tiktokUrl                            String?
  serviceChargePercent                 Float?            @default(0) @map("service_charge_percent")
  brandColors                          Json?
  createdAt                            DateTime          @default(now())
  updatedAt                            DateTime          @updatedAt
  Category                             Category[]
  feedback                             Feedback[]
  Item                                 Item[]
  Media_Media_restaurantIdToRestaurant Media[]           @relation("Media_restaurantIdToRestaurant")
  footerLogo                           Media?            @relation("RestaurantFooterLogo", fields: [footerLogoMediaId], references: [id])
  logo                                 Media?            @relation("RestaurantLogo", fields: [logoMediaId], references: [id])
  welcomeBackground                    Media?            @relation("WelcomeBackground", fields: [welcomeBackgroundMediaId], references: [id])
  RestaurantAdmin                      RestaurantAdmin[]
  sections                             Section[]
  themes                               Theme?
  uiSettings                           UiSettings?
  adminUsers                           AdminUser[]
}

model Section {
  id           String     @id @default(cuid())
  restaurantId String
  nameKu       String
  nameEn       String
  nameAr       String
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  categories   Category[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Category {
  id           String     @id @default(cuid())
  sectionId    String
  nameKu       String
  nameEn       String
  nameAr       String
  imageMediaId String?
  imageR2Key   String?
  imageR2Url   String?
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurantId String
  image        Media?     @relation("CategoryImage", fields: [imageMediaId], references: [id])
  Restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  section      Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  items        Item[]

  @@index([restaurantId])
  @@index([sectionId])
}

model Item {
  id            String     @id @default(cuid())
  categoryId    String
  nameKu        String
  nameEn        String
  nameAr        String
  descriptionKu String?
  descriptionEn String?
  descriptionAr String?
  price         Float
  imageMediaId  String?
  imageR2Key    String?
  imageR2Url    String?
  sortOrder     Int        @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  restaurantId  String
  category      Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  image         Media?     @relation("ItemImage", fields: [imageMediaId], references: [id])
  Restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([restaurantId])
}

model Feedback {
  id                String     @id @default(cuid())
  staffRating       Int
  serviceRating     Int
  hygieneRating     Int
  satisfactionEmoji String?
  phoneNumber       String?
  tableNumber       String?
  comment           String?
  createdAt         DateTime   @default(now())
  restaurantId      String
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Media {
  id                                        String       @id @default(cuid())
  mimeType                                  String
  bytes                                     Bytes
  size                                      Int
  createdAt                                 DateTime     @default(now())
  restaurantId                              String?
  categoryImages                            Category[]   @relation("CategoryImage")
  itemImages                                Item[]       @relation("ItemImage")
  Restaurant_Media_restaurantIdToRestaurant Restaurant?  @relation("Media_restaurantIdToRestaurant", fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantFooterLogos                     Restaurant[] @relation("RestaurantFooterLogo")
  restaurantLogos                           Restaurant[] @relation("RestaurantLogo")
  welcomeBackgrounds                        Restaurant[] @relation("WelcomeBackground")

  @@index([restaurantId])
}

model UiSettings {
  id                    String     @id @default(cuid())
  sectionTitleSize      Int        @default(22)
  categoryTitleSize     Int        @default(16)
  itemNameSize          Int        @default(14)
  itemDescriptionSize   Int        @default(14)
  itemPriceSize         Int        @default(16)
  headerLogoSize        Int        @default(32)
  bottomNavSectionSize  Int        @default(13)
  bottomNavCategorySize Int        @default(13)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  restaurantId          String     @unique
  restaurant            Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model Theme {
  id                        String     @id @default(cuid())
  appBg                     String     @default("#400810")
  menuBackgroundR2Key       String?    @map("menu_background_r2_key")
  menuBackgroundR2Url       String?    @map("menu_background_r2_url")
  itemNameTextColor         String?    @map("item_name_text_color")
  itemPriceTextColor        String?    @map("item_price_text_color")
  itemDescriptionTextColor  String?    @map("item_description_text_color")
  bottomNavSectionNameColor String?    @map("bottom_nav_section_name_color")
  categoryNameColor         String?    @map("category_name_color")
  headerFooterBgColor       String?    @map("header_footer_bg_color")
  glassTintColor            String?    @map("glass_tint_color")
  createdAt                 DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt
  restaurantId              String     @unique
  restaurant                Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model FallbackSettings {
  id                       String   @id @default("fallback-1")
  nameKu                   String   @default("رێستۆرانتی")
  nameEn                   String   @default("Restaurant")
  nameAr                   String   @default("مطعم")
  logoMediaId              String?
  footerLogoMediaId        String?
  welcomeBackgroundMediaId String?
  welcomeOverlayColor      String   @default("#000000")
  welcomeOverlayOpacity    Float    @default(0.5)
  welcomeTextEn            String?
  googleMapsUrl            String?
  phoneNumber              String?
  brandColors              Json?
  sectionTitleSize         Int      @default(22)
  categoryTitleSize        Int      @default(16)
  itemNameSize             Int      @default(14)
  itemDescriptionSize      Int      @default(14)
  itemPriceSize            Int      @default(16)
  headerLogoSize           Int      @default(32)
  bottomNavSectionSize     Int      @default(13)
  bottomNavCategorySize    Int      @default(13)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AdminUser {
  id           String     @id(map: "AdminUser_pkey") @default(cuid())
  pinHash      String     @map("pin_hash")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  restaurantId String     @map("restaurant_id")
  displayName  String?    @map("display_name")
  isActive     Boolean?   @default(true) @map("is_active")
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([restaurantId])
  @@index([restaurantId, isActive])
  @@map("admin_users")
}

model RestaurantAdmin {
  id           String     @id
  restaurantId String
  pinHash      String
  name         String?
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model PlatformSettings {
  id              String   @id
  footerLogoR2Key String?  @map("footer_logo_r2_key")
  footerLogoR2Url String?  @map("footer_logo_r2_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
